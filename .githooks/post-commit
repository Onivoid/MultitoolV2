#!/usr/bin/env bash
set -e

branch=$(git branch --show-current 2>/dev/null || git rev-parse --abbrev-ref HEAD)

if ! node scripts/versioning/should-bump-branch.mjs "$branch"; then
    exit 0
fi

BUMP_FILE=".git/BUMP_VERSION"
BUMP_TAG_FILE=".git/BUMP_TAG"

if [ ! -f "$BUMP_FILE" ]; then
    exit 0
fi

new_version=$(cat "$BUMP_FILE")
rm -f "$BUMP_FILE"

if [ -f "$BUMP_TAG_FILE" ]; then
    tag_name=$(cat "$BUMP_TAG_FILE")
    rm -f "$BUMP_TAG_FILE"
else
    tag_name="v${new_version}"
fi

git tag "$tag_name"

echo ""
echo " ✓ Tag ${tag_name} created locally (version ${new_version})"
echo " → Push it with: git push origin ${tag_name}"
echo ""
