<?xml version="1.0" encoding="utf-8"?>
<!--
  Fragment à fusionner dans Package.appxmanifest (MSIX Packaging Tool)
  avant "Make Package" pour la soumission Microsoft Store.

  Capability restreinte : déclarez "broadFileSystemAccess" dans Partner Center
  (justification : écriture des fichiers de localisation Star Citizen).
-->
<Capabilities xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
              xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities">
  <rescap:Capability Name="broadFileSystemAccess" />
</Capabilities>
